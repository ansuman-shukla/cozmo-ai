COZMO_ENV=development

MONGODB_URI=mongodb://mongodb:27017/cozmo
MONGODB_DB=cozmo
REDIS_URL=redis://redis:6379/0

LIVEKIT_SIP_TRUNK_ID=inbound-trunk-id
LIVEKIT_SIP_DISPATCH_RULE_NAME=cozmo-inbound-dispatch
LIVEKIT_DISPATCH_AGENT_NAME=inbound-agent
CALL_ROOM_PREFIX=call-
TWILIO_TRUNK_NAME=cozmo-inbound

STT_PROVIDER=deepgram
STT_MODEL=nova-3
TTS_PROVIDER=deepgram
TTS_MODEL=aura-2-thalia-en
TTS_VOICE=thalia
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=text-embedding-3-small
KB_TOP_K=3
KB_MIN_SCORE=0.35
MAX_HISTORY_TURNS=10
MAX_JOBS_PER_WORKER_SERVER=8
TIMEOUT_STT_MS=5000
TIMEOUT_LLM_MS=8000
TIMEOUT_TTS_MS=5000
TIMEOUT_KB_MS=200
API_KEY=internal-api-key
LOG_LEVEL=INFO

COZMO_BACKEND_HOST=0.0.0.0
COZMO_BACKEND_PORT=8000
COZMO_BACKEND_CHROMA_URI=http://chromadb:8000
COZMO_BACKEND_LIVEKIT_URL=ws://livekit:7880
COZMO_BACKEND_LIVEKIT_API_KEY=devkey
COZMO_BACKEND_LIVEKIT_API_SECRET=secret
COZMO_BACKEND_METRICS_ENABLED=true
COZMO_BACKEND_AUTO_CREATE_INDEXES=true
COZMO_BACKEND_MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

COZMO_AGENT_LIVEKIT_URL=ws://livekit:7880
COZMO_AGENT_LIVEKIT_API_KEY=devkey
COZMO_AGENT_LIVEKIT_API_SECRET=secret
COZMO_AGENT_BACKEND_BASE_URL=http://backend:8000
COZMO_AGENT_CHROMA_URI=http://chromadb:8000
COZMO_AGENT_WORKER_NAME=cozmo-agent-1
COZMO_AGENT_METRICS_ENABLED=true
COZMO_AGENT_METRICS_PORT=9108
COZMO_AGENT_SYSTEM_METRICS_POLL_INTERVAL_MS=5000
COZMO_AGENT_ROOM_QUALITY_POLL_INTERVAL_MS=5000

COZMO_TWILIO_ACCOUNT_SID=replace-me
COZMO_TWILIO_AUTH_TOKEN=replace-me
COZMO_TWILIO_SIP_DOMAIN=replace-me

COZMO_DEEPGRAM_API_KEY=replace-me
COZMO_GEMINI_API_KEY=replace-me
